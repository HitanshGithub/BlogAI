{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "backend/api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/auth/register",
      "dest": "backend/api/auth/register.js"
    },
    {
      "src": "/api/auth/login",
      "dest": "backend/api/auth/login.js"
    },
    {
      "src": "/api/auth/me",
      "dest": "backend/api/auth/me.js"
    },
    {
      "src": "/api/ai/summarize",
      "dest": "backend/api/ai/summarize.js"
    },
    {
      "src": "/api/blogs/my-blogs",
      "dest": "backend/api/blogs/my-blogs.js"
    },
    {
      "src": "/api/blogs/tags",
      "dest": "backend/api/blogs/tags.js"
    },
    {
      "src": "/api/blogs/([^/]+)/notes",
      "dest": "backend/api/blogs/[id]/notes.js"
    },
    {
      "src": "/api/blogs/([^/]+)",
      "dest": "backend/api/blogs/[id].js"
    },
    {
      "src": "/api/blogs",
      "dest": "backend/api/blogs/index.js"
    },
    {
      "src": "/api/blogs/index",
      "dest": "backend/api/blogs/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
